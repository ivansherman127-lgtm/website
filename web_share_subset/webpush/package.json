{
  "name": "website-slices-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "VITE_DATA_SOURCE=d1 vite",
    "dev:utm": "vite --config vite.config.utm.ts",
    "prebuild": "rm -f public/data/attacking_january_associative_deals_base.json",
    "build": "VITE_DATA_SOURCE=d1 vite build",
    "build:analytics": "VITE_DATA_SOURCE=d1 vite build --config vite.config.analytics.ts",
    "postbuild:utm": "cp dist-utm/utm.html dist-utm/index.html",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "worker:dev:utm": "npm run build:utm && wrangler dev --config wrangler.utm.jsonc",
    "worker:deploy:utm": "npm run build:utm && wrangler deploy --config wrangler.utm.jsonc",
    "worker:dev": "npm run build && wrangler dev",
    "worker:deploy": "npm run build && wrangler deploy",
    "start:server": "node --import tsx/esm server/index.ts",
    "dev:datepicker": "vite --config vite.config.datepicker.ts",
    "build:datepicker": "vite build --config vite.config.datepicker.ts"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^11.9.1",
    "chart.js": "^4.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "~5.6.3",
    "vite": "^8.0.3",
    "wrangler": "^4.77.0"
  }
}
